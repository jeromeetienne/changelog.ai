{
	"name": "changelog.ai",
	"version": "0.1.1",
	"description": "Create and maintain a project's CHANGELOG.md in the Keep a Changelog format — driven by Claude skills on your Claude subscription, no metered API key.",
	"type": "module",
	"bin": {
		"changelog_ai": "dist/cli.js"
	},
	"main": "dist/cli.js",
	"types": "dist/cli.d.ts",
	"files": [
		"dist",
		"dotclaude_folder",
		"LICENSE"
	],
	"engines": {
		"node": ">=20.12"
	},
	"scripts": {
		"changelog_ai": "tsx src/cli.ts",
		"install:dotclaude": "tsx src/cli.ts install .claude --mode symlink",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test 'tests/**/*.test.ts'",
		"test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'",
		"build": "tsc -p tsconfig.build.json",
		"publish:all": "npm run build && npm version patch && npm publish"
	},
	"author": {
		"name": "Jerome Etienne",
		"email": "jerome.etienne@gmail.com"
	},
	"license": "MIT",
	"keywords": [
		"claude-code",
		"changelog",
		"keep-a-changelog",
		"semver",
		"skill"
	],
	"dependencies": {
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
